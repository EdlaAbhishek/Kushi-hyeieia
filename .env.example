# Khushi Hygieia — Environment Variables
# Copy this file to .env and fill in values. Never commit .env to version control.

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5500

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=khushi_hygieia
DB_USER=postgres
DB_PASS=your_db_password_here

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=7d

# AI Provider (OpenRouter)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
